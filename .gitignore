# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/

# Node
node_modules/
dist/
.env

# PlatformIO
firmware/esp32-cam/.pio/
firmware/esp32-actuator/.pio/

# SQLite
*.db

# ML models
server/models/weights/
server/data/cat_photos/

# Edge-PoC bootstrapped datasets — regenerable via
# `python -m training.edge.auto_label bootstrap` (deterministic seed=42).
# Labels (.txt) + manifest.json stay tracked; JPEGs are not.
training/edge/data/labeled/*.jpg
training/edge/data/raw/*.jpg
training/edge/data/calibration_frames/*.jpg
training/edge/data/rejected/*.jpg

# Ultralytics training run dir — plots, optimizer state, batch previews.
# The canonical best.pt is copied to training/edge/models/ which IS tracked.
# Re-running `python -m training.edge.yolo.train_yolov8n_cat` regenerates this.
training/edge/yolo/runs/

# Ultralytics dataset label cache — autogenerated next to the data dir.
training/edge/data/*.cache

# Edge-PoC quantization artifacts — regenerable via
# `python -m training.edge.yolo.export_quantize`. The ONNX intermediate
# (~11 MB) and the SavedModel directory are big and not tracked; the
# canonical .tflite + side-car .export.json are also derived and excluded.
# Re-run quantization to recreate.
training/edge/models/*.onnx
training/edge/models/*.tflite
training/edge/models/*.tflite.export.json
training/edge/models/*_saved_model/

# iter-B imgsz sweep artifacts — regenerable via
# `python -m training.edge.yolo.imgsz_sweep`. One .tflite per imgsz at
# `training/edge/models/sweep_imgsz/yolov8n_cat_distilled_int8_pc_<N>.tflite`.
training/edge/models/sweep_imgsz/

# US-005 QAT intermediate checkpoint — regenerable via
# `python -m training.edge.yolo.qat_finetune`. The downstream artifact
# US-011 actually consumes is the .tflite (also gitignored), so the .pt
# is purely intermediate.
training/edge/models/yolov8n_cat_qat.pt

# onnx2tf-internal calibration sample (auto-downloaded; not part of our PoC).
calibration_image_sample_data_*.npy

# US-007 NanoDet-Plus pretrained download — regenerable via
# `training/edge/nanodet/setup_venv.sh` (curl from the upstream release URL,
# SHA recorded at training/edge/nanodet/checkpoints/SHA256SUMS).
training/edge/nanodet/checkpoints/*.onnx
training/edge/nanodet/checkpoints/*.pth
training/edge/nanodet/checkpoints/*.ckpt
training/edge/nanodet/upstream/
training/edge/nanodet/.upstream_commit

# US-008 NanoDet training run dir — regenerable via
# `python -m training.edge.nanodet.train_nanodet_cat`. The canonical .pth
# is copied to training/edge/nanodet/checkpoints/ (also gitignored).
training/edge/nanodet/runs/

# Superpowers
.superpowers/

# Claude
.claude/

# IDE
.vscode/
.idea/
